---
config:
  theme: base
  look: neo
  themeVariables:
    primaryColor: '#C5E0B4'
    primaryTextColor: '#231f20'
    secondaryColor: '#EEEEEE'
    lineColor: '#385723'    
    fontSize: 12px
    tertiaryTextColor: '#231f20'
    fontFamily: 'Fira Sans, trebuchet ms, verdana, arial'
---
flowchart TB
  linkStyle default stroke:#385723,stroke-width: 2px;

  subgraph inputs[Workflow Inputs]
    direction TB
    trial_id(trial_id)
    sensorthingsapi_url(sensorthingsapi_url)
    ndvi_file(ndvi_file)
    geojson_file(geojson_file)
    sowing_date(sowing_date)
    harvest_date(harvest_date)
    results_csv(results_csv)
    visualization_png(visualization_png)
    template_path(template_path)
    experiment_id(experiment_id)
    lon(lon)
    lat(lat)
    radius(radius)
    vars(vars)
    gs_codes(gs_codes)
    depth_seq(depth_seq)
    paw(paw)
    total_n(total_n)
    simulations_output_dir(simulations_output_dir)
    plot_output_file(plot_output_file)
    plot_treatment_labels(plot_treatment_labels)
    plot_legend_title(plot_legend_title)
  end

  subgraph outputs[Workflow Outputs]
    direction TB
    phenology_results_png(phenology_results_png)
    phenology_results_csv(phenology_results_csv)
    ndvi_timeseries(ndvi_timeseries)
    field_data_out(field_data)
    production_season_out(production_season)
    sensor_data_out(sensor_data)
    sensor_data_icasa_out(sensor_data_icasa)
    nasa_data_out(nasa_data)
    nasa_data_icasa_out(nasa_data_icasa)
    soil_data_out(soil_data)
    gs_dates_out(gs_dates)
    gs_dates_icasa_out(gs_dates_icasa)
    assembled_icasa_out(assembled_icasa)
    dataset_dssat_out(dataset_dssat)
    normalized_soil_out(normalized_soil)
    initial_layers_out(initial_layers)
    simulations_dir_out(simulations_dir)
    growth_plot_out(growth_plot)
  end

  %% ── Phenology branch ──────────────────────────────────────────────────────
  fetch-ndvi(fetch-ndvi)
  trial_id            --> |trial_id|fetch-ndvi
  sensorthingsapi_url --> |sensorthingsapi_url|fetch-ndvi
  ndvi_file           --> |ndvi_file|fetch-ndvi

  phenology-analyzer(phenology-analyzer)
  fetch-ndvi        --> |ndvi_file|phenology-analyzer
  geojson_file      --> |geojson_file|phenology-analyzer
  sowing_date       --> |sowing_date|phenology-analyzer
  harvest_date      --> |harvest_date|phenology-analyzer
  results_csv       --> |results_csv|phenology-analyzer
  visualization_png --> |visualization_png|phenology-analyzer

  phenology-analyzer --> |phenology_results_png|phenology_results_png
  phenology-analyzer --> |phenology_results_csv|phenology_results_csv
  fetch-ndvi         --> |ndvi_timeseries|ndvi_timeseries

  %% ── Field data ────────────────────────────────────────────────────────────
  get-field-data(get-field-data)
  template_path --> |template_path|get-field-data
  experiment_id --> |experiment_id|get-field-data
  get-field-data_headers(long)
  get-field-data_headers --> |headers|get-field-data

  identify-production-season(identify-production-season)
  get-field-data --> |field_data|identify-production-season

  get-field-data              --> |field_data|field_data_out
  identify-production-season  --> |production_season|production_season_out

  %% ── Sensor + NASA weather ─────────────────────────────────────────────────
  get-sensor-data(get-sensor-data)
  lon    --> |lon|get-sensor-data
  lat    --> |lat|get-sensor-data
  identify-production-season --> |season_file|get-sensor-data
  radius --> |radius|get-sensor-data
  vars   --> |vars|get-sensor-data

  convert-sensor-data-icasa(convert-sensor-data-icasa)
  get-sensor-data --> |sensor_data|convert-sensor-data-icasa
  conv_sen_from(user)
  conv_sen_from --> |from_format|convert-sensor-data-icasa
  conv_sen_uc(na)
  conv_sen_uc --> |unmatched_code|convert-sensor-data-icasa

  get-weather-data(get-weather-data)
  lon --> |lon|get-weather-data
  lat --> |lat|get-weather-data
  identify-production-season --> |season_file|get-weather-data

  convert-nasa-data-icasa(convert-nasa-data-icasa)
  get-weather-data --> |nasa_data|convert-nasa-data-icasa

  get-sensor-data           --> |sensor_data|sensor_data_out
  convert-sensor-data-icasa --> |sensor_data_icasa|sensor_data_icasa_out
  get-weather-data          --> |nasa_data|nasa_data_out
  convert-nasa-data-icasa   --> |nasa_data_icasa|nasa_data_icasa_out

  %% ── Soil profile ──────────────────────────────────────────────────────────
  get-soil-profile(get-soil-profile)
  lon --> |lon|get-soil-profile
  lat --> |lat|get-soil-profile

  get-soil-profile --> |soil_data|soil_data_out

  %% ── Growth stage dates ────────────────────────────────────────────────────
  lookup-gs-dates(lookup-gs-dates)
  phenology-analyzer --> |phenology_results_csv|lookup-gs-dates
  gs_codes --> |gs_codes|lookup-gs-dates

  convert-gs-dates-icasa(convert-gs-dates-icasa)
  lookup-gs-dates --> |gs_dates|convert-gs-dates-icasa

  lookup-gs-dates        --> |gs_dates|gs_dates_out
  convert-gs-dates-icasa --> |gs_dates_icasa|gs_dates_icasa_out

  %% ── Dataset assembly ──────────────────────────────────────────────────────
  assemble-icasa-dataset(assemble-icasa-dataset)
  convert-sensor-data-icasa --> |sensor_icasa|assemble-icasa-dataset
  convert-nasa-data-icasa   --> |nasa_icasa|assemble-icasa-dataset
  get-soil-profile          --> |soil_data|assemble-icasa-dataset
  get-field-data            --> |field_data|assemble-icasa-dataset
  convert-gs-dates-icasa    --> |gs_dates_icasa|assemble-icasa-dataset

  convert-icasa-dssat(convert-icasa-dssat)
  assemble-icasa-dataset --> |assembled_icasa|convert-icasa-dssat

  assemble-icasa-dataset --> |assembled_icasa|assembled_icasa_out
  convert-icasa-dssat    --> |dataset_dssat|dataset_dssat_out

  %% ── Soil normalisation + initial conditions ───────────────────────────────
  normalize-soil-profile(normalize-soil-profile)
  convert-icasa-dssat --> |dataset_dssat|normalize-soil-profile

  calculate-initial-layers(calculate-initial-layers)
  convert-icasa-dssat --> |dataset_dssat|calculate-initial-layers

  normalize-soil-profile   --> |normalized_soil|normalized_soil_out
  calculate-initial-layers --> |initial_layers|initial_layers_out

  %% ── DSSAT simulation ──────────────────────────────────────────────────────
  build-simulation-files(build-simulation-files)
  convert-icasa-dssat --> |dataset_dssat|build-simulation-files
  depth_seq --> |depth_seq|build-simulation-files
  paw       --> |paw|build-simulation-files
  total_n   --> |total_n|build-simulation-files

  run-simulations(run-simulations)
  build-simulation-files --> |filex|run-simulations
  build-simulation-files --> |soil_file|run-simulations
  build-simulation-files --> |weather_files|run-simulations
  simulations_output_dir --> |output_dir|run-simulations

  %% ── Plot results ──────────────────────────────────────────────────────────
  plot-results(plot-results)
  run-simulations       --> |simulations_dir|plot-results
  plot_output_file      --> |output_file|plot-results
  plot_treatment_labels --> |treatment_labels|plot-results
  plot_legend_title     --> |legend_title|plot-results

  run-simulations --> |simulations_dir|simulations_dir_out
  plot-results    --> |growth_plot|growth_plot_out

