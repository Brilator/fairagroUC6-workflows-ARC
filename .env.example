# Copy this file to .env and fill in your FROST SensorThings API credentials.
# .env is gitignored — never commit real credentials.

FROST_USERNAME=your_username@example.com
FROST_PASSWORD=your_password
FROST_USER_URL=https://your-frost-server/FROST-Server/v1.0/
FROST_CLIENT_ID=your_client_id
FROST_CLIENT_SECRET=your_client_secret
